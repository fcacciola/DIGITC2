<Window x:Class="DIGITC2_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DIGITC2_App.Controls"
        Title="DIGITC2" Height="1080" Width="1920" WindowState="Maximized">
    <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="4" VerticalAlignment="Top">
            <Button x:Name="LoadButton" Width="80" Margin="2" Click="LoadButton_Click">LOAD</Button>
            <Button x:Name="ProcessButton" Width="80" Margin="2" Click="ProcessButton_Click">PROCESS</Button>
            <Button x:Name="ViewButton" Width="80" Margin="2" Click="ViewButton_Click">VIEW</Button>
            <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="4,0"/>
                <Slider x:Name="ZoomSlider" Minimum="0.1" Maximum="16" Width="150" Value="1" TickFrequency="0.1" IsSnapToTickEnabled="False"/>
                <TextBlock Text="Offset:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <Slider x:Name="OffsetSlider" Minimum="0" Maximum="1000" Width="200" />
            </StackPanel>
        </StackPanel>

        <DockPanel DockPanel.Dock="Top">
            <Border BorderBrush="Gray" BorderThickness="1" Margin="4" DockPanel.Dock="Top">
                <controls:WaveformView x:Name="InputWaveView" Height="120" BackgroundBrush="#FFF5F0E8" WaveformPenBrush="#4169E1" GridLineBrush="#B0C4DE"
                                       Zoom="{Binding ElementName=ZoomSlider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       Offset="{Binding ElementName=OffsetSlider, Path=Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Border>
        </DockPanel>

        <StatusBar DockPanel.Dock="Top" BorderBrush="Black" BorderThickness="1,1,1,1" Height="200">
          <StatusBarItem VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <ScrollViewer x:Name="StatusTextScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
              <TextBlock x:Name="StatusText" Text="" VerticalAlignment="Top" TextWrapping="Wrap" Margin="4" />
            </ScrollViewer>
          </StatusBarItem>
        </StatusBar>

    <!-- Results tab control: each tab corresponds to a subfolder in the output folder; shows result.txt content -->
        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <TabControl x:Name="ResultsTabControl" Margin="4" />
        </ScrollViewer>


    </DockPanel>
</Window>